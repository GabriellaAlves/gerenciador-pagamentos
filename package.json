{
  "name": "gerenciador-pagamentos",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "jest-junit": {
    "outputDirectory": "./test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabriellaAlves/gerenciador-pagamentos.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/GabriellaAlves/gerenciador-pagamentos/issues"
  },
  "homepage": "https://github.com/GabriellaAlves/gerenciador-pagamentos#readme",
  "dependencies": {
    "mocha": "^11.7.6"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4"
  }
}
