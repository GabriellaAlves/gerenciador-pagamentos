{
  "name": "gerenciador-pagamentos",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:ci": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "jest-junit": {
    "outputDirectory": "./test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabriellaAlves/gerenciador-pagamentos.git"
  },
  "keywords": [],
  "author": "Gabriella Alves",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/GabriellaAlves/gerenciador-pagamentos/issues"
  },
  "homepage": "https://github.com/GabriellaAlves/gerenciador-pagamentos#readme",
  "dependencies": {
    "mocha": "^11.7.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4"
  }
}
